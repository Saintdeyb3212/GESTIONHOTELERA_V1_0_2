{
  "name": "Hotel Walay Peru - Autenticacion de dos factores",
  "version": "1.0.0",
  "source": "Mockup visual generado para LoginWith2fa",
  "scope": "/Account/LoginWith2fa",
  "layout": {
    "type": "split-screen",
    "desktopColumns": ["38%", "62%"],
    "mobileBreakpoint": 820,
    "cardMaxWidth": 820,
    "cardRadius": 28
  },
  "palette": {
    "gold100": "#fff8df",
    "gold200": "#f9e8a6",
    "gold300": "#f2cf65",
    "gold400": "#dcae38",
    "gold500": "#bd851a",
    "gold600": "#94610e",
    "ink950": "#0b0b0b",
    "ink900": "#121212",
    "ink800": "#1d1d1d",
    "cream50": "#fffdf8",
    "cream100": "#fbf7ee",
    "line": "#ead8aa"
  },
  "typography": {
    "display": "Georgia, Times New Roman, serif",
    "body": "system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "headingWeight": 700,
    "buttonWeight": 800
  },
  "components": {
    "brandPanel": {
      "background": "dark luxury gradient",
      "elements": ["HW monogram", "security shield", "gold orbital lines", "trust message"]
    },
    "authenticationCard": {
      "background": "rgba(255,255,255,0.94)",
      "shadow": "0 24px 75px rgba(22,17,8,0.16)",
      "elements": ["hotel brand", "2FA heading", "authenticator input", "remember device", "primary action", "recovery link"]
    }
  },
  "accessibility": {
    "minimumContrast": "AA",
    "keyboardFocus": true,
    "reducedMotionSupport": true,
    "responsive": true
  }
}
