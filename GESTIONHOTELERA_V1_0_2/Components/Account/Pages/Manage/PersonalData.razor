@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor

<PageTitle>Personal Data</PageTitle>

<StatusMessage />
<h3>Datos personales</h3>

<div class="row">
    <div class="col-md-6">
        <p>Tu cuenta contiene datos personales que nos has proporcionado. Esta pßgina te permite descargar o eliminar dichos datos.</p>
        <p>
            <strong>
                Eliminar estos datos supondrß la eliminaciˇn permanente de su cuenta, y esta no podrß recuperarse.
            </strong>
        </p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">Descargar</button>
        </form>
        <p>
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">Borrar</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}
