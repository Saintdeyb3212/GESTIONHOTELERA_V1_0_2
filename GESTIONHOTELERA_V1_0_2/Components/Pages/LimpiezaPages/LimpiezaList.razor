@page "/limpiezas"
@page "/limpieza"
@using GESTIONHOTELERA_V1_0_2.Data.ENTIDADES
@using GESTIONHOTELERA_V1_0_2.Data.REPOSITORIO.IREPOSITORIO
@using GESTIONHOTELERA_V1_0_2.Aplication.SERVICIOS
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Administrador,Empleado,Limpieza")]
@inject ILimpiezaRepositorio LimpiezaRepositorio
@inject IHabitacionRepositorio HabitacionRepositorio
@inject ILimpiezaServicio LimpiezaServicio

<PageTitle>Limpieza</PageTitle>

<h3>Gestión de limpieza</h3>
<p class="text-muted">
    Asigna habitaciones usadas a limpieza, registra el inicio y finalización del trabajo, y devuelve la habitación a estado disponible.
</p>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @claseMensaje alert-dismissible fade show" role="alert">
        @mensaje
        <button type="button" class="btn-close" @onclick="LimpiarMensaje" aria-label="Cerrar"></button>
    </div>
}

@if (cargando)
{
    <p>Cargando limpiezas...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Pendientes de asignar</div>
                    <div class="fs-3 fw-bold">@habitacionesPendientes.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Limpiezas pendientes</div>
                    <div class="fs-3 fw-bold">@limpiezas.Count(l => l.EstadoLimpieza == EstadosLimpieza.Pendiente && l.Activo)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">En proceso</div>
                    <div class="fs-3 fw-bold">@limpiezas.Count(l => l.EstadoLimpieza == EstadosLimpieza.EnProceso && l.Activo)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Finalizadas</div>
                    <div class="fs-3 fw-bold">@limpiezas.Count(l => l.EstadoLimpieza == EstadosLimpieza.Finalizada && l.Activo)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Asignar limpieza</div>
                <div class="card-body">
                    <EditForm Model="asignacion" OnValidSubmit="AsignarAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Habitación pendiente</label>
                            <InputSelect class="form-select" @bind-Value="asignacion.IdHabitacion">
                                <option value="0">Seleccione habitación</option>
                                @foreach (var habitacion in habitacionesPendientes)
                                {
                                    <option value="@habitacion.IdHabitacion">
                                        @habitacion.NumeroHabitacion - @habitacion.TipoHabitacion?.NombreTipoHabitacion
                                    </option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Responsable</label>
                            <InputText class="form-control" @bind-Value="asignacion.Responsable" placeholder="Nombre del responsable" />
                            <ValidationMessage For="() => asignacion.Responsable" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Observación</label>
                            <InputTextArea class="form-control" @bind-Value="asignacion.Observacion" rows="3" placeholder="Detalle opcional" />
                            <ValidationMessage For="() => asignacion.Observacion" />
                        </div>

                        <button class="btn btn-primary w-100" type="submit" disabled="@(!habitacionesPendientes.Any())">
                            Asignar limpieza
                        </button>
                    </EditForm>

                    @if (!habitacionesPendientes.Any())
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            No hay habitaciones pendientes de limpieza. Cuando una reserva haga check-out aparecerá aquí.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Finalizar limpieza seleccionada</div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <select class="form-select" @bind="idLimpiezaFinalizar">
                                <option value="0">Seleccione limpieza abierta</option>
                                @foreach (var limpieza in limpiezasAbiertas)
                                {
                                    <option value="@limpieza.IdLimpieza">
                                        Hab. @limpieza.Habitacion?.NumeroHabitacion - @limpieza.ResponsableLimpieza - @limpieza.EstadoLimpieza
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-5">
                            <input class="form-control" @bind="observacionFinalizacion" placeholder="Observación final opcional" />
                        </div>
                        <div class="col-md-2 d-grid">
                            <button class="btn btn-success" @onclick="FinalizarSeleccionadaAsync" disabled="@(idLimpiezaFinalizar == 0)">
                                Finalizar
                            </button>
                        </div>
                    </div>
                    <div class="form-text">
                        Al finalizar, la habitación vuelve automáticamente a estado Disponible.
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Historial de limpiezas</div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-5">
                            <input class="form-control" @bind="criterio" @bind:event="oninput" placeholder="Buscar por responsable, habitación, estado u observación" />
                        </div>
                        <div class="col-md-4">
                            <select class="form-select" @bind="filtroEstado">
                                <option value="Todos">Todos los estados</option>
                                <option value="@EstadosLimpieza.Pendiente">Pendiente</option>
                                <option value="@EstadosLimpieza.EnProceso">En Proceso</option>
                                <option value="@EstadosLimpieza.Finalizada">Finalizada</option>
                                <option value="@EstadosLimpieza.Cancelada">Cancelada</option>
                            </select>
                        </div>
                        <div class="col-md-3 d-grid">
                            <button class="btn btn-outline-secondary" @onclick="RecargarAsync">Actualizar</button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Habitación</th>
                                    <th>Tipo</th>
                                    <th>Responsable</th>
                                    <th>Estado</th>
                                    <th>Asignación</th>
                                    <th>Inicio</th>
                                    <th>Finalización</th>
                                    <th>Observación</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var limpieza in LimpiezasFiltradas)
                                {
                                    <tr>
                                        <td>@limpieza.Habitacion?.NumeroHabitacion</td>
                                        <td>@limpieza.Habitacion?.TipoHabitacion?.NombreTipoHabitacion</td>
                                        <td>@limpieza.ResponsableLimpieza</td>
                                        <td><span class="badge @ClaseEstado(limpieza.EstadoLimpieza)">@limpieza.EstadoLimpieza</span></td>
                                        <td>@FormatoFecha(limpieza.FechaAsignacion)</td>
                                        <td>@FormatoFecha(limpieza.FechaInicio)</td>
                                        <td>@FormatoFecha(limpieza.FechaFinalizacion)</td>
                                        <td>@(string.IsNullOrWhiteSpace(limpieza.Observacion) ? "-" : limpieza.Observacion)</td>
                                        <td class="text-end">
                                            @if (limpieza.EstadoLimpieza == EstadosLimpieza.Pendiente)
                                            {
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => IniciarAsync(limpieza.IdLimpieza)">
                                                    Iniciar
                                                </button>
                                            }
                                            @if (limpieza.EstadoLimpieza is EstadosLimpieza.Pendiente or EstadosLimpieza.EnProceso)
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => PrepararFinalizacion(limpieza.IdLimpieza)">
                                                    Finalizar
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!LimpiezasFiltradas.Any())
                    {
                        <div class="alert alert-info mb-0">No se encontraron limpiezas con los filtros actuales.</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly AsignarLimpiezaForm asignacion = new();
    private List<Limpieza> limpiezas = new List<Limpieza>();
    private List<Habitacion> habitacionesPendientes = new List<Habitacion>();
    private bool cargando = true;
    private string? mensaje;
    private string claseMensaje = "alert-success";
    private string criterio = string.Empty;
    private string filtroEstado = "Todos";
    private int idLimpiezaFinalizar;
    private string? observacionFinalizacion;

    private IEnumerable<Limpieza> limpiezasAbiertas => limpiezas
        .Where(l => l.Activo && l.EstadoLimpieza is EstadosLimpieza.Pendiente or EstadosLimpieza.EnProceso)
        .OrderBy(l => l.FechaAsignacion);

    private IEnumerable<Limpieza> LimpiezasFiltradas
    {
        get
        {
            var query = limpiezas.AsEnumerable();

            if (filtroEstado != "Todos")
            {
                query = query.Where(l => l.EstadoLimpieza == filtroEstado);
            }

            if (!string.IsNullOrWhiteSpace(criterio))
            {
                var texto = criterio.Trim();
                query = query.Where(l =>
                    l.ResponsableLimpieza.Contains(texto, StringComparison.OrdinalIgnoreCase)
                    || l.EstadoLimpieza.Contains(texto, StringComparison.OrdinalIgnoreCase)
                    || (l.Habitacion?.NumeroHabitacion?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (l.Habitacion?.TipoHabitacion?.NombreTipoHabitacion?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (l.Observacion?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            return query.OrderByDescending(l => l.FechaAsignacion);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        cargando = true;
        limpiezas = (await LimpiezaRepositorio.GetAllAsync(incluirInactivos: true)).ToList();
        habitacionesPendientes = (await HabitacionRepositorio.GetPendientesLimpiezaAsync()).ToList();
        cargando = false;
    }

    private async Task AsignarAsync()
    {
        var resultado = await LimpiezaServicio.AsignarLimpiezaAsync(
            asignacion.IdHabitacion,
            asignacion.Responsable,
            asignacion.Observacion);

        MostrarResultado(resultado.Exitoso, resultado.Mensaje);

        if (resultado.Exitoso)
        {
            asignacion.IdHabitacion = 0;
            asignacion.Responsable = string.Empty;
            asignacion.Observacion = null;
            await RecargarAsync();
        }
    }

    private async Task IniciarAsync(int idLimpieza)
    {
        var resultado = await LimpiezaServicio.IniciarLimpiezaAsync(idLimpieza);
        MostrarResultado(resultado.Exitoso, resultado.Mensaje);
        await RecargarAsync();
    }

    private void PrepararFinalizacion(int idLimpieza)
    {
        idLimpiezaFinalizar = idLimpieza;
        observacionFinalizacion = string.Empty;
    }

    private async Task FinalizarSeleccionadaAsync()
    {
        if (idLimpiezaFinalizar == 0)
        {
            MostrarResultado(false, "Debe seleccionar una limpieza para finalizar.");
            return;
        }

        var resultado = await LimpiezaServicio.FinalizarLimpiezaAsync(idLimpiezaFinalizar, observacionFinalizacion);
        MostrarResultado(resultado.Exitoso, resultado.Mensaje);

        if (resultado.Exitoso)
        {
            idLimpiezaFinalizar = 0;
            observacionFinalizacion = null;
            await RecargarAsync();
        }
    }

    private void MostrarResultado(bool exitoso, string? texto)
    {
        claseMensaje = exitoso ? "alert-success" : "alert-danger";
        mensaje = texto;
    }

    private void LimpiarMensaje()
    {
        mensaje = null;
    }

    private static string FormatoFecha(DateTime? fecha)
    {
        return fecha?.ToLocalTime().ToString("g") ?? "Pendiente";
    }

    private static string ClaseEstado(string estado)
    {
        return estado switch
        {
            EstadosLimpieza.Pendiente => "text-bg-warning",
            EstadosLimpieza.EnProceso => "text-bg-primary",
            EstadosLimpieza.Finalizada => "text-bg-success",
            EstadosLimpieza.Cancelada => "text-bg-secondary",
            _ => "text-bg-light"
        };
    }

    private sealed class AsignarLimpiezaForm
    {
        public int IdHabitacion { get; set; }

        [Required(ErrorMessage = "El responsable es obligatorio.")]
        [StringLength(150, ErrorMessage = "El responsable no puede superar 150 caracteres.")]
        public string Responsable { get; set; } = string.Empty;

        [StringLength(500, ErrorMessage = "La observación no puede superar 500 caracteres.")]
        public string? Observacion { get; set; }
    }
}
