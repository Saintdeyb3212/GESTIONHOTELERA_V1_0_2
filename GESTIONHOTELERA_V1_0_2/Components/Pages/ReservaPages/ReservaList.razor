@page "/reservas"
@using GESTIONHOTELERA_V1_0_2.Data.ENTIDADES
@using GESTIONHOTELERA_V1_0_2.Data.REPOSITORIO.IREPOSITORIO
@using GESTIONHOTELERA_V1_0_2.Aplication.SERVICIOS
@using GESTIONHOTELERA_V1_0_2.Aplication.SERVICIOS.MODELOS
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrador,Empleado,Recepcion")]
@inject IReservaRepositorio ReservaRepositorio
@inject IHabitacionRepositorio HabitacionRepositorio
@inject IClienteRepositorio ClienteRepositorio
@inject IReservaServicio ReservaServicio

<PageTitle>Reservas</PageTitle>

<h3>Reservas</h3>
<p class="text-muted">Registra reservas con cliente, una o varias habitaciones, validación de disponibilidad, check-in, check-out y cancelación.</p>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(operacionExitosa ? "alert-success" : "alert-danger")" role="alert">@mensaje</div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">@(modoEdicion ? "Editar reserva" : "Nueva reserva")</div>
            <div class="card-body">
                @if (modoEdicion)
                {
                    <EditForm Model="formularioEdicion" OnValidSubmit="ActualizarReservaAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label" for="editCheckIn">Check-in</label>
                                <InputDate id="editCheckIn" class="form-control" @bind-Value="formularioEdicion.FechaCheckInProgramada" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="editCheckOut">Check-out</label>
                                <InputDate id="editCheckOut" class="form-control" @bind-Value="formularioEdicion.FechaCheckOutProgramada" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label" for="editHuespedes">Huéspedes</label>
                            <InputNumber id="editHuespedes" class="form-control" @bind-Value="formularioEdicion.CantidadHuespedes" />
                        </div>

                        <div class="mt-3">
                            <label class="form-label">Habitaciones</label>
                            <div class="border rounded p-2 habitaciones-selector">
                                @foreach (var habitacion in habitaciones)
                                {
                                    var seleccionada = formularioEdicion.HabitacionesSeleccionadas.Contains(habitacion.IdHabitacion);
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" checked="@seleccionada" @onchange="e => CambiarHabitacionEdicion(habitacion.IdHabitacion, e)" id="edit-hab-@habitacion.IdHabitacion" />
                                        <label class="form-check-label" for="edit-hab-@habitacion.IdHabitacion">
                                            @habitacion.NumeroHabitacion - @habitacion.TipoHabitacion?.NombreTipoHabitacion (@Capacidad(habitacion) pax) - @habitacion.EstadoHabitacion
                                        </label>
                                    </div>
                                }
                            </div>
                            <small class="text-muted">Solo se permite editar reservas pendientes o confirmadas.</small>
                        </div>

                        <div class="mt-3">
                            <label class="form-label" for="editObservaciones">Observaciones</label>
                            <InputTextArea id="editObservaciones" class="form-control" rows="2" @bind-Value="formularioEdicion.Observaciones" />
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">Actualizar</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelarEdicion">Cancelar</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <EditForm Model="formularioCreacion" OnValidSubmit="CrearReservaAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <h6 class="text-uppercase text-muted">Cliente</h6>

                        <div class="border rounded p-3 mb-3 bg-light">
                            <label class="form-label fw-semibold" for="buscarClienteReserva">Buscar cliente registrado</label>
                            <div class="input-group">
                                <input id="buscarClienteReserva"
                                       class="form-control"
                                       placeholder="Escriba nombres, apellidos o documento"
                                       @bind="criterioBusquedaCliente"
                                       @bind:event="oninput" />
                                <button type="button" class="btn btn-outline-primary" @onclick="BuscarClientesParaReservaAsync">
                                    Buscar
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="PrepararClienteNuevo">
                                    Cliente nuevo
                                </button>
                            </div>
                            <small class="text-muted">Seleccione un cliente existente o complete manualmente los datos para registrar uno nuevo.</small>

                            @if (!string.IsNullOrWhiteSpace(mensajeBusquedaCliente))
                            {
                                <div class="small mt-2 @(clienteSeleccionado is null ? "text-muted" : "text-success")">
                                    @mensajeBusquedaCliente
                                </div>
                            }

                            @if (busquedaClienteRealizada && clientesEncontrados.Any())
                            {
                                <div class="list-group mt-3">
                                    @foreach (var cliente in clientesEncontrados)
                                    {
                                        <button type="button"
                                                class="list-group-item list-group-item-action"
                                                @onclick="() => SeleccionarClienteExistente(cliente)">
                                            <div class="d-flex w-100 justify-content-between gap-2">
                                                <strong>@NombreCompleto(cliente)</strong>
                                                <span class="badge bg-secondary">@cliente.TipoDocumento @cliente.NumeroDocumento</span>
                                            </div>
                                            <small class="text-muted">
                                                @(string.IsNullOrWhiteSpace(cliente.Telefono) ? "Sin teléfono" : cliente.Telefono)
                                                · @(string.IsNullOrWhiteSpace(cliente.Email) ? "Sin correo" : cliente.Email)
                                            </small>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        @if (clienteSeleccionado is not null)
                        {
                            <div class="alert alert-success py-2 d-flex justify-content-between align-items-center gap-2" role="status">
                                <span>
                                    Cliente seleccionado: <strong>@NombreCompleto(clienteSeleccionado)</strong>
                                </span>
                                <button type="button" class="btn btn-sm btn-outline-success" @onclick="PrepararClienteNuevo">
                                    Cambiar
                                </button>
                            </div>
                        }

                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label" for="nombres">Nombres</label>
                                <InputText id="nombres" class="form-control" @bind-Value="formularioCreacion.Cliente.Nombres" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="apellidos">Apellidos</label>
                                <InputText id="apellidos" class="form-control" @bind-Value="formularioCreacion.Cliente.Apellidos" />
                            </div>
                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-md-4">
                                <label class="form-label" for="tipoDocumento">Tipo</label>
                                <InputSelect id="tipoDocumento" class="form-select" @bind-Value="formularioCreacion.Cliente.TipoDocumento">
                                    <option value="DNI">DNI</option>
                                    <option value="CE">CE</option>
                                    <option value="PASAPORTE">Pasaporte</option>
                                    <option value="RUC">RUC</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label" for="numeroDocumento">Documento</label>
                                <InputText id="numeroDocumento" class="form-control" @bind-Value="formularioCreacion.Cliente.NumeroDocumento" @onblur="BuscarClientePorDocumentoAsync" />
                            </div>
                        </div>

                        <div class="row g-2 mt-1">
                            <div class="col-md-6">
                                <label class="form-label" for="telefono">Teléfono</label>
                                <InputText id="telefono" class="form-control" @bind-Value="formularioCreacion.Cliente.Telefono" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="email">Correo</label>
                                <InputText id="email" class="form-control" @bind-Value="formularioCreacion.Cliente.Email" />
                            </div>
                        </div>

                        <div class="mt-2">
                            <label class="form-label" for="direccion">Dirección</label>
                            <InputTextArea id="direccion" class="form-control" rows="2" @bind-Value="formularioCreacion.Cliente.Direccion" />
                        </div>

                        <hr />
                        <h6 class="text-uppercase text-muted">Reserva</h6>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label" for="checkIn">Check-in</label>
                                <InputDate id="checkIn" class="form-control" @bind-Value="formularioCreacion.FechaCheckInProgramada" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="checkOut">Check-out</label>
                                <InputDate id="checkOut" class="form-control" @bind-Value="formularioCreacion.FechaCheckOutProgramada" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label" for="huespedes">Huéspedes</label>
                            <InputNumber id="huespedes" class="form-control" @bind-Value="formularioCreacion.CantidadHuespedes" />
                        </div>

                        <div class="mt-3">
                            <label class="form-label">Habitaciones disponibles</label>
                            <div class="border rounded p-2 habitaciones-selector">
                                @foreach (var habitacion in habitacionesDisponibles)
                                {
                                    var seleccionada = formularioCreacion.HabitacionesSeleccionadas.Contains(habitacion.IdHabitacion);
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" checked="@seleccionada" @onchange="e => CambiarHabitacionCreacion(habitacion.IdHabitacion, e)" id="hab-@habitacion.IdHabitacion" />
                                        <label class="form-check-label" for="hab-@habitacion.IdHabitacion">
                                            @habitacion.NumeroHabitacion - @habitacion.TipoHabitacion?.NombreTipoHabitacion (@Capacidad(habitacion) pax) - @Precio(habitacion)
                                        </label>
                                    </div>
                                }
                                @if (!habitacionesDisponibles.Any())
                                {
                                    <span class="text-muted">No hay habitaciones disponibles. Revise estados, limpieza o tipos activos.</span>
                                }
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label" for="observaciones">Observaciones</label>
                            <InputTextArea id="observaciones" class="form-control" rows="2" @bind-Value="formularioCreacion.Observaciones" />
                        </div>

                        <button type="submit" class="btn btn-primary mt-3">Registrar reserva</button>
                    </EditForm>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <input class="form-control" placeholder="Buscar por cliente, documento o estado" @bind="criterioBusqueda" @bind:event="oninput" />
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" @bind="estadoFiltro">
                            <option value="">Todos los estados</option>
                            @foreach (var estado in estadosReserva)
                            {
                                <option value="@estado">@estado</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 d-grid">
                        <button class="btn btn-outline-primary" @onclick="BuscarAsync">Buscar</button>
                    </div>
                </div>
            </div>
            <div class="card-body table-responsive">
                @if (reservas is null)
                {
                    <p>Cargando...</p>
                }
                else
                {
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Habitaciones</th>
                                <th>Estado</th>
                                <th>Programado</th>
                                <th>Real</th>
                                <th>Total</th>
                                <th>Pagado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reserva in reservas)
                            {
                                <tr>
                                    <td>
                                        <strong>@reserva.Cliente?.Apellidos, @reserva.Cliente?.Nombres</strong><br />
                                        <small class="text-muted">@reserva.Cliente?.TipoDocumento @reserva.Cliente?.NumeroDocumento</small>
                                    </td>
                                    <td>@string.Join(", ", reserva.DetallesReserva.Select(d => d.Habitacion.NumeroHabitacion))</td>
                                    <td><span class="badge @ClaseEstado(reserva.EstadoReserva)">@reserva.EstadoReserva</span></td>
                                    <td>
                                        In: @reserva.FechaCheckInProgramada.ToShortDateString()<br />
                                        Out: @reserva.FechaCheckOutProgramada.ToShortDateString()
                                    </td>
                                    <td>
                                        In: @(reserva.FechaCheckInReal?.ToString("g") ?? "Pendiente")<br />
                                        Out: @(reserva.FechaCheckOutReal?.ToString("g") ?? "Pendiente")
                                    </td>
                                    <td>@FormatoMoneda(reserva.TotalEstimado)</td>
                                    <td>@FormatoMoneda(reserva.Pagos.Where(p => p.Activo).Sum(p => p.Monto))</td>
                                    <td>
                                        <div class="btn-group btn-group-sm flex-wrap" role="group">
                                            <button class="btn btn-outline-secondary" disabled="@(!PuedeEditar(reserva))" @onclick="() => PrepararEdicion(reserva)">Editar</button>
                                            <button class="btn btn-outline-success" disabled="@(reserva.EstadoReserva != EstadosReserva.Pendiente)" @onclick="() => ConfirmarAsync(reserva.IdReserva)">Confirmar</button>
                                            <button class="btn btn-outline-primary" disabled="@(!PuedeCheckIn(reserva))" @onclick="() => CheckInAsync(reserva.IdReserva)">Check-in</button>
                                            <button class="btn btn-outline-warning" disabled="@(reserva.EstadoReserva != EstadosReserva.CheckIn)" @onclick="() => CheckOutAsync(reserva.IdReserva)">Check-out</button>
                                            <button class="btn btn-outline-danger" disabled="@(!PuedeCancelar(reserva))" @onclick="() => CancelarAsync(reserva.IdReserva)">Cancelar</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Reserva>? reservas;
    private List<Habitacion> habitaciones = new List<Habitacion>();
    private List<Habitacion> habitacionesDisponibles = new List<Habitacion>();
    private CrearReservaRequest formularioCreacion = new CrearReservaRequest();
    private ActualizarReservaRequest formularioEdicion = new();
    private bool modoEdicion;
    private string? mensaje;
    private bool operacionExitosa;
    private string criterioBusqueda = string.Empty;
    private string estadoFiltro = string.Empty;
    private string criterioBusquedaCliente = string.Empty;
    private string? mensajeBusquedaCliente;
    private bool busquedaClienteRealizada;
    private List<Cliente> clientesEncontrados = new List<Cliente>();
    private Cliente? clienteSeleccionado;

    private readonly string[] estadosReserva = new[]
    {
        EstadosReserva.Pendiente,
        EstadosReserva.Confirmada,
        EstadosReserva.CheckIn,
        EstadosReserva.Completada,
        EstadosReserva.Cancelada
    };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosAsync();
    }

    private async Task CargarDatosAsync()
    {
        reservas = (await ReservaRepositorio.GetAllAsync(incluirInactivos: true)).ToList();
        habitaciones = (await HabitacionRepositorio.GetAllAsync(incluirInactivos: false)).ToList();
        habitacionesDisponibles = habitaciones
            .Where(h => h.Activo && h.EstadoHabitacion == EstadosHabitacion.Disponible && h.TipoHabitacion.Activo)
            .OrderBy(h => h.NumeroHabitacion)
            .ToList();
    }

    private async Task BuscarAsync()
    {
        IEnumerable<Reserva> resultado;
        if (!string.IsNullOrWhiteSpace(criterioBusqueda))
        {
            resultado = await ReservaRepositorio.BuscarAsync(criterioBusqueda, incluirInactivos: true);
        }
        else
        {
            resultado = await ReservaRepositorio.GetAllAsync(incluirInactivos: true);
        }

        if (!string.IsNullOrWhiteSpace(estadoFiltro))
        {
            resultado = resultado.Where(r => r.EstadoReserva == estadoFiltro);
        }

        reservas = resultado.ToList();
    }

    private async Task CrearReservaAsync()
    {
        var resultado = await ReservaServicio.CrearReservaAsync(formularioCreacion);
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);

        if (resultado.Exitoso)
        {
            formularioCreacion = new CrearReservaRequest();
            ReiniciarBusquedaCliente();
        }
    }

    private async Task ActualizarReservaAsync()
    {
        var resultado = await ReservaServicio.ActualizarReservaAsync(formularioEdicion);
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);

        if (resultado.Exitoso)
        {
            CancelarEdicion();
        }
    }

    private async Task ConfirmarAsync(int idReserva)
    {
        var resultado = await ReservaServicio.ConfirmarAsync(idReserva);
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);
    }

    private async Task CheckInAsync(int idReserva)
    {
        var resultado = await ReservaServicio.RegistrarCheckInAsync(idReserva, DateTime.UtcNow);
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);
    }

    private async Task CheckOutAsync(int idReserva)
    {
        var resultado = await ReservaServicio.RegistrarCheckOutAsync(idReserva, DateTime.UtcNow);
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);
    }

    private async Task CancelarAsync(int idReserva)
    {
        var resultado = await ReservaServicio.CancelarAsync(idReserva, "Cancelada desde módulo de reservas.");
        await ProcesarResultadoAsync(resultado.Exitoso, resultado.Mensaje);
    }

    private void PrepararEdicion(Reserva reserva)
    {
        modoEdicion = true;
        formularioEdicion = new ActualizarReservaRequest
        {
            IdReserva = reserva.IdReserva,
            FechaCheckInProgramada = reserva.FechaCheckInProgramada,
            FechaCheckOutProgramada = reserva.FechaCheckOutProgramada,
            CantidadHuespedes = reserva.CantidadHuespedes,
            Observaciones = reserva.Observaciones,
            HabitacionesSeleccionadas = reserva.DetallesReserva.Select(d => d.IdHabitacion).ToList()
        };
    }

    private void CancelarEdicion()
    {
        modoEdicion = false;
        formularioEdicion = new ActualizarReservaRequest();
    }

    private async Task BuscarClientesParaReservaAsync()
    {
        busquedaClienteRealizada = true;
        clientesEncontrados = new List<Cliente>();
        mensajeBusquedaCliente = null;

        var criterio = criterioBusquedaCliente.Trim();
        if (criterio.Length < 2)
        {
            mensajeBusquedaCliente = "Escriba al menos 2 caracteres para buscar un cliente.";
            return;
        }

        clientesEncontrados = (await ClienteRepositorio.BuscarAsync(criterio))
            .Where(c => c.Activo)
            .Take(10)
            .ToList();

        if (!clientesEncontrados.Any())
        {
            mensajeBusquedaCliente = "No se encontraron clientes registrados. Puede completar los datos como cliente nuevo.";
        }
    }

    private void SeleccionarClienteExistente(Cliente cliente)
    {
        clienteSeleccionado = CopiarCliente(cliente);
        formularioCreacion.Cliente = CopiarCliente(cliente);
        criterioBusquedaCliente = NombreCompleto(cliente);
        clientesEncontrados = new List<Cliente>();
        busquedaClienteRealizada = false;
        mensajeBusquedaCliente = $"Se cargaron los datos de {NombreCompleto(cliente)}.";
    }

    private void PrepararClienteNuevo()
    {
        formularioCreacion.Cliente = new Cliente
        {
            TipoDocumento = "DNI",
            Activo = true
        };

        ReiniciarBusquedaCliente();
        mensajeBusquedaCliente = "Complete los datos para registrar un cliente nuevo.";
    }

    private void ReiniciarBusquedaCliente()
    {
        criterioBusquedaCliente = string.Empty;
        clientesEncontrados = new List<Cliente>();
        busquedaClienteRealizada = false;
        clienteSeleccionado = null;
        mensajeBusquedaCliente = null;
    }

    private static Cliente CopiarCliente(Cliente cliente)
    {
        return new Cliente
        {
            IdCliente = cliente.IdCliente,
            Nombres = cliente.Nombres,
            Apellidos = cliente.Apellidos,
            TipoDocumento = cliente.TipoDocumento,
            NumeroDocumento = cliente.NumeroDocumento,
            Telefono = cliente.Telefono,
            Email = cliente.Email,
            Direccion = cliente.Direccion,
            Activo = true
        };
    }

    private static string NombreCompleto(Cliente cliente)
    {
        return $"{cliente.Nombres} {cliente.Apellidos}".Trim();
    }

    private async Task BuscarClientePorDocumentoAsync()
    {
        var documento = formularioCreacion.Cliente.NumeroDocumento?.Trim();
        if (string.IsNullOrWhiteSpace(documento))
        {
            return;
        }

        var clientes = await ClienteRepositorio.BuscarAsync(documento, incluirInactivos: true);
        var cliente = clientes.FirstOrDefault(c => c.NumeroDocumento == documento);
        if (cliente is null)
        {
            return;
        }

        SeleccionarClienteExistente(cliente);
    }

    private void CambiarHabitacionCreacion(int idHabitacion, ChangeEventArgs e)
    {
        CambiarSeleccion(formularioCreacion.HabitacionesSeleccionadas, idHabitacion, e);
    }

    private void CambiarHabitacionEdicion(int idHabitacion, ChangeEventArgs e)
    {
        CambiarSeleccion(formularioEdicion.HabitacionesSeleccionadas, idHabitacion, e);
    }

    private static void CambiarSeleccion(List<int> seleccion, int idHabitacion, ChangeEventArgs e)
    {
        var marcado = e.Value is bool valor && valor;
        if (marcado && !seleccion.Contains(idHabitacion))
        {
            seleccion.Add(idHabitacion);
        }
        else if (!marcado)
        {
            seleccion.Remove(idHabitacion);
        }
    }

    private async Task ProcesarResultadoAsync(bool exitoso, string texto)
    {
        operacionExitosa = exitoso;
        mensaje = texto;
        await CargarDatosAsync();
        await BuscarAsync();
    }

    private static bool PuedeEditar(Reserva reserva) => reserva.EstadoReserva is EstadosReserva.Pendiente or EstadosReserva.Confirmada;
    private static bool PuedeCheckIn(Reserva reserva) => reserva.EstadoReserva is EstadosReserva.Pendiente or EstadosReserva.Confirmada;
    private static bool PuedeCancelar(Reserva reserva) => reserva.EstadoReserva is not (EstadosReserva.Completada or EstadosReserva.Cancelada);


    private static string Precio(Habitacion habitacion) => FormatoMoneda(habitacion.TipoHabitacion?.PrecioPorNoche ?? 0);

    private static string FormatoMoneda(decimal monto) => $"S/. {monto:N2}";
    private static int Capacidad(Habitacion habitacion) => habitacion.TipoHabitacion?.CapacidadPersonas ?? 0;

    private static string ClaseEstado(string estado) => estado switch
    {
        EstadosReserva.Pendiente => "bg-secondary",
        EstadosReserva.Confirmada => "bg-info text-dark",
        EstadosReserva.CheckIn => "bg-primary",
        EstadosReserva.Completada => "bg-success",
        EstadosReserva.Cancelada => "bg-danger",
        _ => "bg-secondary"
    };
}
