@page "/habitaciones"
@using GESTIONHOTELERA_V1_0_2.Data.ENTIDADES
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Administrador,Empleado,Recepcion")]
@inject IHabitacionServicio HabitacionServicio
@inject ITipoHabitacionServicio TipoHabitacionServicio

<PageTitle>Habitaciones</PageTitle>

<h3>Habitaciones</h3>
<p class="text-muted">Registra, edita, visualiza y activa/desactiva habitaciones. Las habitaciones inactivas no aparecen como disponibles para reservas.</p>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(operacionExitosa ? "alert-success" : "alert-danger")" role="alert">@mensaje</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">@(formulario.IdHabitacion == 0 ? "Nueva habitación" : "Editar habitación")</div>
            <div class="card-body">
                <EditForm Model="formulario" OnValidSubmit="GuardarAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label" for="numeroHabitacion">Número</label>
                        <InputText id="numeroHabitacion" class="form-control" @bind-Value="formulario.NumeroHabitacion" />
                        <ValidationMessage For="() => formulario.NumeroHabitacion" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="piso">Piso</label>
                        <InputText id="piso" class="form-control" @bind-Value="formulario.Piso" />
                        <ValidationMessage For="() => formulario.Piso" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="tipoHabitacion">Tipo</label>
                        <InputSelect id="tipoHabitacion" class="form-select" @bind-Value="formulario.IdTipoHabitacion">
                            <option value="0">Seleccione...</option>
                            @foreach (var tipo in tiposActivos)
                            {
                                <option value="@tipo.IdTipoHabitacion">@tipo.NombreTipoHabitacion - @tipo.CapacidadPersonas pax - @FormatoMoneda(tipo.PrecioPorNoche)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => formulario.IdTipoHabitacion" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="descripcionHabitacion">Descripción</label>
                        <InputTextArea id="descripcionHabitacion" class="form-control" rows="3" @bind-Value="formulario.DescripcionHabitacion" />
                        <ValidationMessage For="() => formulario.DescripcionHabitacion" />
                    </div>

                    @if (formulario.IdHabitacion != 0 && formulario.Activo && estadosEditables.Contains(formulario.EstadoHabitacion))
                    {
                        <div class="mb-3">
                            <label class="form-label" for="estadoHabitacion">Estado operativo</label>
                            <InputSelect id="estadoHabitacion" class="form-select" @bind-Value="formulario.EstadoHabitacion">
                                @foreach (var estado in estadosEditables)
                                {
                                    <option value="@estado">@estado</option>
                                }
                            </InputSelect>
                            <div class="form-text">Estados como Reservada u Ocupada se cambian automáticamente desde Reservas.</div>
                        </div>
                    }
                    else if (formulario.IdHabitacion != 0)
                    {
                        <div class="alert alert-info">
                            Estado actual: <strong>@formulario.EstadoHabitacion</strong>. Este estado se controla desde Reservas o Limpieza.
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@procesando">Guardar</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarFormulario" disabled="@procesando">Nuevo</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <div class="row g-2 align-items-center">
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Buscar por número, piso, tipo o estado" @bind="criterioBusqueda" @bind:event="oninput" />
                    </div>
                    <div class="col-md-3">
                        <InputSelect class="form-select" @bind-Value="estadoFiltro">
                            <option value="">Todos los estados</option>
                            @foreach (var estado in estadosFiltro)
                            {
                                <option value="@estado">@estado</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <div class="form-check">
                            <InputCheckbox id="verInactivas" class="form-check-input" @bind-Value="incluirInactivos" />
                            <label class="form-check-label" for="verInactivas">Inactivas</label>
                        </div>
                    </div>
                    <div class="col-md-1 d-grid">
                        <button type="button" class="btn btn-outline-primary" @onclick="BuscarAsync">Buscar</button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                @if (habitaciones is null)
                {
                    <p class="p-3">Cargando...</p>
                }
                else if (!HabitacionesFiltradas.Any())
                {
                    <p class="p-3 mb-0">No se encontraron habitaciones.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Número</th>
                                    <th>Tipo</th>
                                    <th>Capacidad</th>
                                    <th>Precio/Noche</th>
                                    <th>Estado</th>
                                    <th>Activo</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var habitacion in HabitacionesFiltradas)
                                {
                                    <tr>
                                        <td>
                                            <strong>@habitacion.NumeroHabitacion</strong><br />
                                            <small class="text-muted">Piso: @(habitacion.Piso ?? "Sin registrar")</small>
                                        </td>
                                        <td>@habitacion.TipoHabitacion?.NombreTipoHabitacion</td>
                                        <td>@habitacion.TipoHabitacion?.CapacidadPersonas</td>
                                        <td>@(habitacion.TipoHabitacion is null ? "-" : FormatoMoneda(habitacion.TipoHabitacion.PrecioPorNoche))</td>
                                        <td><span class="badge @CssEstado(habitacion.EstadoHabitacion)">@habitacion.EstadoHabitacion</span></td>
                                        <td><span class="badge @(habitacion.Activo ? "text-bg-success" : "text-bg-secondary")">@(habitacion.Activo ? "Activo" : "Inactivo")</span></td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditarAsync(habitacion.IdHabitacion)">Editar</button>
                                            @if (habitacion.Activo)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DesactivarAsync(habitacion.IdHabitacion)">Desactivar</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => ActivarAsync(habitacion.IdHabitacion)">Activar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Habitacion> habitaciones = new List<Habitacion>();
    private List<TipoHabitacion> tiposActivos = new List<TipoHabitacion>();
    private HabitacionForm formulario = new();
    private string criterioBusqueda = string.Empty;
    private string estadoFiltro = string.Empty;
    private bool incluirInactivos = true;
    private string? mensaje;
    private bool operacionExitosa;
    private bool procesando;

    private readonly string[] estadosEditables =
    [
        EstadosHabitacion.Disponible,
        EstadosHabitacion.Mantenimiento,
        EstadosHabitacion.PendienteLimpieza,
        EstadosHabitacion.EnLimpieza
    ];

    private readonly string[] estadosFiltro =
    [
        EstadosHabitacion.Disponible,
        EstadosHabitacion.Reservada,
        EstadosHabitacion.Ocupada,
        EstadosHabitacion.PendienteLimpieza,
        EstadosHabitacion.EnLimpieza,
        EstadosHabitacion.Mantenimiento,
        EstadosHabitacion.Inactiva
    ];

    private IEnumerable<Habitacion> HabitacionesFiltradas => string.IsNullOrWhiteSpace(estadoFiltro)
        ? habitaciones
        : habitaciones.Where(h => h.EstadoHabitacion == estadoFiltro);

    protected override async Task OnInitializedAsync()
    {
        await CargarCombosAsync();
        await CargarHabitacionesAsync();
    }

    private async Task CargarCombosAsync()
    {
        tiposActivos = (await TipoHabitacionServicio.ObtenerTodosAsync()).ToList();
    }

    private async Task CargarHabitacionesAsync()
    {
        habitaciones = (await HabitacionServicio.ObtenerTodasAsync(incluirInactivos)).ToList();
    }

    private async Task BuscarAsync()
    {
        habitaciones = (await HabitacionServicio.BuscarAsync(criterioBusqueda, incluirInactivos)).ToList();
    }

    private async Task GuardarAsync()
    {
        procesando = true;
        mensaje = null;

        var entidad = new Habitacion
        {
            IdHabitacion = formulario.IdHabitacion,
            NumeroHabitacion = formulario.NumeroHabitacion,
            Piso = formulario.Piso,
            DescripcionHabitacion = formulario.DescripcionHabitacion,
            IdTipoHabitacion = formulario.IdTipoHabitacion,
            EstadoHabitacion = formulario.EstadoHabitacion,
            Activo = formulario.Activo
        };

        var resultado = await HabitacionServicio.GuardarAsync(entidad);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;

        if (resultado.Exitoso)
        {
            if (formulario.IdHabitacion != 0 && formulario.Activo && estadosEditables.Contains(formulario.EstadoHabitacion))
            {
                var estadoResultado = await HabitacionServicio.CambiarEstadoAsync(formulario.IdHabitacion, formulario.EstadoHabitacion);
                mensaje = estadoResultado.Exitoso ? mensaje : estadoResultado.Mensaje;
                operacionExitosa = operacionExitosa && estadoResultado.Exitoso;
            }

            LimpiarFormulario();
            await BuscarAsync();
        }

        procesando = false;
    }

    private async Task EditarAsync(int id)
    {
        var habitacion = await HabitacionServicio.ObtenerPorIdAsync(id);
        if (habitacion is null)
        {
            mensaje = "No se encontró la habitación.";
            operacionExitosa = false;
            return;
        }

        formulario = new HabitacionForm
        {
            IdHabitacion = habitacion.IdHabitacion,
            NumeroHabitacion = habitacion.NumeroHabitacion,
            Piso = habitacion.Piso,
            DescripcionHabitacion = habitacion.DescripcionHabitacion,
            IdTipoHabitacion = habitacion.IdTipoHabitacion,
            EstadoHabitacion = habitacion.EstadoHabitacion,
            Activo = habitacion.Activo
        };
    }

    private async Task ActivarAsync(int id)
    {
        var resultado = await HabitacionServicio.ActivarAsync(id);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;
        await CargarCombosAsync();
        await BuscarAsync();
    }

    private async Task DesactivarAsync(int id)
    {
        var resultado = await HabitacionServicio.DesactivarAsync(id);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;
        await BuscarAsync();
    }

    private void LimpiarFormulario()
    {
        formulario = new HabitacionForm();
    }

    private static string CssEstado(string estado)
    {
        return estado switch
        {
            EstadosHabitacion.Disponible => "text-bg-success",
            EstadosHabitacion.Reservada => "text-bg-primary",
            EstadosHabitacion.Ocupada => "text-bg-warning",
            EstadosHabitacion.PendienteLimpieza => "text-bg-info",
            EstadosHabitacion.EnLimpieza => "text-bg-info",
            EstadosHabitacion.Mantenimiento => "text-bg-danger",
            EstadosHabitacion.Inactiva => "text-bg-secondary",
            _ => "text-bg-light"
        };
    }

    private static string FormatoMoneda(decimal monto) => $"S/. {monto:N2}";

    private sealed class HabitacionForm
    {
        public int IdHabitacion { get; set; }

        [Required(ErrorMessage = "El número de habitación es obligatorio.")]
        [StringLength(20, ErrorMessage = "El número no puede tener más de 20 caracteres.")]
        public string NumeroHabitacion { get; set; } = string.Empty;

        [StringLength(100, ErrorMessage = "El piso no puede tener más de 100 caracteres.")]
        public string? Piso { get; set; }

        [StringLength(500, ErrorMessage = "La descripción no puede tener más de 500 caracteres.")]
        public string? DescripcionHabitacion { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Debes seleccionar un tipo de habitación.")]
        public int IdTipoHabitacion { get; set; }

        public string EstadoHabitacion { get; set; } = EstadosHabitacion.Disponible;
        public bool Activo { get; set; } = true;
    }
}
