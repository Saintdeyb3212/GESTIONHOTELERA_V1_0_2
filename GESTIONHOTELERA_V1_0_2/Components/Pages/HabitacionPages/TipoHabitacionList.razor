@page "/tipos-habitacion"
@using GESTIONHOTELERA_V1_0_2.Data.ENTIDADES
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrador,Empleado,Recepcion")]
@inject ITipoHabitacionServicio TipoHabitacionServicio

<PageTitle>Tipos de Habitación</PageTitle>

<h3>Tipos de habitación</h3>
<p class="text-muted">Administra capacidad, precio por noche y estado activo/inactivo. No se elimina información físicamente.</p>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(operacionExitosa ? "alert-success" : "alert-danger")" role="alert">@mensaje</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">@(formulario.IdTipoHabitacion == 0 ? "Nuevo tipo" : "Editar tipo")</div>
            <div class="card-body">
                <EditForm Model="formulario" OnValidSubmit="GuardarAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label" for="nombreTipo">Nombre</label>
                        <InputText id="nombreTipo" class="form-control" @bind-Value="formulario.NombreTipoHabitacion" />
                        <ValidationMessage For="() => formulario.NombreTipoHabitacion" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="descripcionTipo">Descripción</label>
                        <InputTextArea id="descripcionTipo" class="form-control" rows="3" @bind-Value="formulario.DescripcionTipoHabitacion" />
                        <ValidationMessage For="() => formulario.DescripcionTipoHabitacion" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="capacidad">Capacidad de personas</label>
                        <InputNumber id="capacidad" class="form-control" @bind-Value="formulario.CapacidadPersonas" />
                        <ValidationMessage For="() => formulario.CapacidadPersonas" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="precio">Precio por noche</label>
                        <InputNumber id="precio" class="form-control" @bind-Value="formulario.PrecioPorNoche" />
                        <ValidationMessage For="() => formulario.PrecioPorNoche" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@procesando">Guardar</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarFormulario" disabled="@procesando">Nuevo</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <div class="row g-2 align-items-center">
                    <div class="col-md-7">
                        <input class="form-control" placeholder="Buscar por nombre o descripción" @bind="criterioBusqueda" @bind:event="oninput" />
                    </div>
                    <div class="col-md-3">
                        <div class="form-check">
                            <InputCheckbox id="incluirInactivos" class="form-check-input" @bind-Value="incluirInactivos" />
                            <label class="form-check-label" for="incluirInactivos">Ver inactivos</label>
                        </div>
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="button" class="btn btn-outline-primary" @onclick="BuscarAsync">Buscar</button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                @if (tiposHabitacion is null)
                {
                    <p class="p-3">Cargando...</p>
                }
                else if (!tiposHabitacion.Any())
                {
                    <p class="p-3 mb-0">No se encontraron tipos de habitación.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Capacidad</th>
                                    <th>Precio/Noche</th>
                                    <th>Activo</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tipo in tiposHabitacion)
                                {
                                    <tr>
                                        <td>
                                            <strong>@tipo.NombreTipoHabitacion</strong><br />
                                            <small class="text-muted">@tipo.DescripcionTipoHabitacion</small>
                                        </td>
                                        <td>@tipo.CapacidadPersonas</td>
                                        <td>@FormatoMoneda(tipo.PrecioPorNoche)</td>
                                        <td><span class="badge @(tipo.Activo ? "text-bg-success" : "text-bg-secondary")">@(tipo.Activo ? "Activo" : "Inactivo")</span></td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => Editar(tipo.IdTipoHabitacion)">Editar</button>
                                            @if (tipo.Activo)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DesactivarAsync(tipo.IdTipoHabitacion)">Desactivar</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => ActivarAsync(tipo.IdTipoHabitacion)">Activar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<TipoHabitacion> tiposHabitacion = new List<TipoHabitacion>();
    private TipoHabitacionForm formulario = new();
    private string criterioBusqueda = string.Empty;
    private bool incluirInactivos = true;
    private string? mensaje;
    private bool operacionExitosa;
    private bool procesando;

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        tiposHabitacion = (await TipoHabitacionServicio.ObtenerTodosAsync(incluirInactivos)).ToList();
    }

    private async Task BuscarAsync()
    {
        tiposHabitacion = (await TipoHabitacionServicio.BuscarAsync(criterioBusqueda, incluirInactivos)).ToList();
    }

    private async Task GuardarAsync()
    {
        procesando = true;
        mensaje = null;

        var entidad = new TipoHabitacion
        {
            IdTipoHabitacion = formulario.IdTipoHabitacion,
            NombreTipoHabitacion = formulario.NombreTipoHabitacion,
            DescripcionTipoHabitacion = formulario.DescripcionTipoHabitacion,
            CapacidadPersonas = formulario.CapacidadPersonas,
            PrecioPorNoche = formulario.PrecioPorNoche,
            Activo = formulario.Activo
        };

        var resultado = await TipoHabitacionServicio.GuardarAsync(entidad);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;

        if (resultado.Exitoso)
        {
            LimpiarFormulario();
            await BuscarAsync();
        }

        procesando = false;
    }

    private async Task Editar(int id)
    {
        var tipo = await TipoHabitacionServicio.ObtenerPorIdAsync(id);
        if (tipo is null)
        {
            mensaje = "No se encontró el tipo de habitación.";
            operacionExitosa = false;
            return;
        }

        formulario = new TipoHabitacionForm
        {
            IdTipoHabitacion = tipo.IdTipoHabitacion,
            NombreTipoHabitacion = tipo.NombreTipoHabitacion,
            DescripcionTipoHabitacion = tipo.DescripcionTipoHabitacion,
            CapacidadPersonas = tipo.CapacidadPersonas,
            PrecioPorNoche = tipo.PrecioPorNoche,
            Activo = tipo.Activo
        };
    }

    private async Task ActivarAsync(int id)
    {
        var resultado = await TipoHabitacionServicio.ActivarAsync(id);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;
        await BuscarAsync();
    }

    private async Task DesactivarAsync(int id)
    {
        var resultado = await TipoHabitacionServicio.DesactivarAsync(id);
        mensaje = resultado.Mensaje;
        operacionExitosa = resultado.Exitoso;
        await BuscarAsync();
    }

    private void LimpiarFormulario()
    {
        formulario = new TipoHabitacionForm();
    }

    private static string FormatoMoneda(decimal monto) => $"S/. {monto:N2}";

    private sealed class TipoHabitacionForm
    {
        public int IdTipoHabitacion { get; set; }

        [Required(ErrorMessage = "El nombre es obligatorio.")]
        [StringLength(100, ErrorMessage = "El nombre no puede tener más de 100 caracteres.")]
        public string NombreTipoHabitacion { get; set; } = string.Empty;

        [StringLength(500, ErrorMessage = "La descripción no puede tener más de 500 caracteres.")]
        public string? DescripcionTipoHabitacion { get; set; }

        [Range(1, 20, ErrorMessage = "La capacidad debe estar entre 1 y 20 personas.")]
        public int CapacidadPersonas { get; set; } = 1;

        [Range(0.01, 999999.99, ErrorMessage = "El precio debe ser mayor que cero.")]
        public decimal PrecioPorNoche { get; set; } = 1m;

        public bool Activo { get; set; } = true;
    }
}
